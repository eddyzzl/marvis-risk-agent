{
  "name": "modeling",
  "version": "0.4.5",
  "display_name": "Modeling Pack",
  "description": "Modeling readiness, frame preparation, feature selection, training, experiment comparison, PMML export, and V1 validation handoff tools.",
  "module": "marvis.packs.modeling.tools",
  "python_requires": ">=3.10,<3.14",
  "tools": [
    {
      "name": "check_data_quality",
      "summary": "Check modeling data quality issues without changing deterministic metrics.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "dataset_id"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "issues": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "issues"
        ],
        "additionalProperties": false
      },
      "determinism": "deterministic",
      "timeout_seconds": 120,
      "failure_policy": "fail",
      "entrypoint": "tool_check_data_quality",
      "side_effects": [
        "read:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "modeling_readiness",
      "summary": "Evaluate whether a dataset is ready for binary modeling.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "split_col": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "dataset_id",
          "target_col"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ready": {
            "type": "boolean"
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "stats": {
            "type": "object"
          }
        },
        "required": [
          "ready",
          "blockers",
          "warnings",
          "stats"
        ],
        "additionalProperties": false
      },
      "determinism": "deterministic",
      "timeout_seconds": 120,
      "failure_policy": "fail",
      "entrypoint": "tool_modeling_readiness",
      "side_effects": [
        "read:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "prepare_modeling_frame",
      "summary": "Create a derived modeling frame with selected columns and deterministic splits.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "feature_cols": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0
          },
          "split_col": {
            "type": "string",
            "minLength": 1
          },
          "split_config": {
            "type": "object"
          },
          "passthrough_cols": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "seed": {
            "type": "integer"
          }
        },
        "required": [
          "dataset_id",
          "target_col",
          "feature_cols"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result_dataset_id": {
            "type": "string"
          },
          "split_counts": {
            "type": "object"
          },
          "split_col": {
            "type": "string"
          },
          "split_values": {
            "type": "object"
          },
          "holdout_values": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "feature_cols": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "result_dataset_id",
          "split_counts"
        ],
        "additionalProperties": false
      },
      "determinism": "stochastic",
      "timeout_seconds": 120,
      "failure_policy": "fail",
      "entrypoint": "tool_prepare_modeling_frame",
      "side_effects": [
        "read:dataset",
        "write:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "make_split",
      "summary": "MODELING G1 split gate: build a derived modeling frame from an arbitrary condition rule set plus the existing random/time fallback, and return per-split counts with a per-split x month/channel distribution table for confirmation.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "feature_cols": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0
          },
          "split_config": {
            "type": "object"
          },
          "passthrough_cols": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "seed": {
            "type": "integer"
          },
          "split_col": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "dataset_id",
          "target_col",
          "feature_cols"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result_dataset_id": {
            "type": "string"
          },
          "sample_analysis": {
            "type": "object",
            "properties": {
              "split_counts": {
                "type": "object"
              },
              "total_rows": {
                "type": "integer",
                "minimum": 0
              },
              "group_distributions": {
                "type": "object"
              }
            },
            "required": [
              "split_counts",
              "total_rows",
              "group_distributions"
            ],
            "additionalProperties": false
          },
          "split_col": {
            "type": "string"
          },
          "split_values": {
            "type": "object"
          },
          "holdout_values": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "feature_cols": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "result_dataset_id",
          "split_col",
          "sample_analysis"
        ],
        "additionalProperties": false
      },
      "determinism": "stochastic",
      "timeout_seconds": 120,
      "failure_policy": "fail",
      "entrypoint": "tool_make_split",
      "side_effects": [
        "read:dataset",
        "write:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "screen_features",
      "summary": "Leakage-aware univariate KS/IV screen over a wide candidate set; flags suspected target leakage (very high single-feature KS) and model-output/score columns, and proposes a clean candidate set for user confirmation.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "target_type": {
            "type": "string"
          },
          "split_col": {
            "type": "string",
            "minLength": 1
          },
          "holdout_values": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "leakage_ks": {
            "type": "number"
          },
          "max_missing_rate": {
            "type": "number"
          },
          "top_k": {
            "type": "integer",
            "minimum": 1
          },
          "batch_size": {
            "type": "integer",
            "minimum": 1
          }
        },
        "required": [
          "dataset_id",
          "features",
          "target_col"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "selected": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ranked": {
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "leakage": {
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "suspected": {
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "unusable": {
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "scores": {
            "type": "object"
          },
          "n_screened": {
            "type": "integer",
            "minimum": 0
          },
          "note": {
            "type": "string"
          }
        },
        "required": [
          "selected",
          "ranked",
          "leakage",
          "suspected",
          "unusable",
          "scores"
        ],
        "additionalProperties": false
      },
      "determinism": "deterministic",
      "timeout_seconds": 300,
      "failure_policy": "fail",
      "entrypoint": "tool_screen_features",
      "side_effects": [
        "read:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "select_features",
      "summary": "Select modeling features using IV, correlation, VIF, and optional top-k filters.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "iv_min": {
            "type": "number"
          },
          "corr_max": {
            "type": "number"
          },
          "vif_max": {
            "type": "number"
          },
          "top_k": {
            "type": "integer",
            "minimum": 1
          },
          "drop_nan_labels": {
            "type": "boolean"
          }
        },
        "required": [
          "dataset_id",
          "features",
          "target_col"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "selected": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dropped": {
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "scores": {
            "type": "object"
          },
          "nan_labels_dropped": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "selected",
          "dropped",
          "scores"
        ],
        "additionalProperties": false
      },
      "determinism": "deterministic",
      "timeout_seconds": 120,
      "failure_policy": "fail",
      "entrypoint": "tool_select_features",
      "side_effects": [
        "read:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "tune_hyperparameters",
      "summary": "Random-search LightGBM hyperparameters (seeded), selecting by test KS minus an overfit penalty; OOT is the unbiased final metric. Returns best_params for train_model.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "split_col": {
            "type": "string",
            "minLength": 1
          },
          "split_values": {
            "type": "object"
          },
          "recipe": {
            "type": "string",
            "minLength": 1
          },
          "sample_weight_col": {
            "type": "string"
          },
          "n_trials": {
            "type": "integer",
            "minimum": 1
          },
          "early_stopping_rounds": {
            "type": "integer",
            "minimum": 1
          },
          "max_boost_round": {
            "type": "integer",
            "minimum": 1
          },
          "overfit_penalty": {
            "type": "number"
          },
          "seed": {
            "type": "integer"
          }
        },
        "required": [
          "dataset_id",
          "features",
          "target_col",
          "split_col",
          "split_values"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "best_params": {
            "type": "object"
          },
          "best_metrics": {
            "type": "object"
          },
          "n_trials": {
            "type": "integer",
            "minimum": 0
          },
          "trials": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "best_params",
          "best_metrics",
          "n_trials"
        ],
        "additionalProperties": false
      },
      "determinism": "stochastic",
      "timeout_seconds": 1800,
      "failure_policy": "fail",
      "entrypoint": "tool_tune_hyperparameters",
      "side_effects": [
        "read:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "train_model",
      "summary": "Train one modeling recipe and persist experiment metrics plus model artifacts.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "recipe": {
            "type": "string",
            "enum": [
              "lgb",
              "xgb",
              "catboost",
              "lr",
              "scorecard",
              "mlp",
              "lgb_regressor",
              "lgb_multiclass"
            ]
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "split_col": {
            "type": "string",
            "minLength": 1
          },
          "split_values": {
            "type": "object"
          },
          "params": {
            "type": "object"
          },
          "sample_weight_col": {
            "type": "string"
          },
          "seed": {
            "type": "integer"
          },
          "scenario": {
            "type": "string",
            "minLength": 1
          },
          "early_stopping_rounds": {
            "type": "integer",
            "minimum": 1
          },
          "drop_nan_labels": {
            "type": "boolean"
          }
        },
        "required": [
          "dataset_id",
          "recipe",
          "features",
          "target_col",
          "split_col",
          "split_values",
          "seed"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "experiment_id": {
            "type": "string"
          },
          "artifact_id": {
            "type": "string"
          },
          "metrics": {
            "type": "object"
          },
          "feature_importance": {
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "nan_labels_dropped": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "experiment_id",
          "artifact_id",
          "metrics",
          "feature_importance"
        ],
        "additionalProperties": false
      },
      "determinism": "stochastic",
      "timeout_seconds": 180,
      "failure_policy": "fail",
      "entrypoint": "tool_train_model",
      "side_effects": [
        "read:dataset",
        "write:model",
        "write:dataset",
        "write:experiment"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "train_models",
      "summary": "Train one or more recipes and return all experiments plus the best by OOT KS (test KS fallback). lgb uses the tuned params; other recipes train with their own defaults. The single-recipe case mirrors train_model.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "recipes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "lgb",
                "xgb",
                "catboost",
                "lr",
                "scorecard",
                "mlp",
                "lgb_regressor",
                "lgb_multiclass"
              ]
            },
            "minItems": 1
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "split_col": {
            "type": "string",
            "minLength": 1
          },
          "split_values": {
            "type": "object"
          },
          "params": {
            "type": "object"
          },
          "sample_weight_col": {
            "type": "string"
          },
          "seed": {
            "type": "integer"
          },
          "target_type": {
            "type": "string"
          },
          "drop_nan_labels": {
            "type": "boolean"
          }
        },
        "required": [
          "dataset_id",
          "recipes",
          "features",
          "target_col",
          "split_col",
          "split_values",
          "seed"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "experiments": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "experiment_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "best_experiment_id": {
            "type": "string"
          },
          "best_recipe": {
            "type": "string"
          },
          "target_type": {
            "type": "string"
          },
          "selection_metric": {
            "type": "string"
          }
        },
        "required": [
          "experiments",
          "experiment_ids",
          "best_experiment_id",
          "best_recipe",
          "target_type",
          "selection_metric"
        ],
        "additionalProperties": false
      },
      "determinism": "stochastic",
      "timeout_seconds": 600,
      "failure_policy": "fail",
      "entrypoint": "tool_train_models",
      "side_effects": [
        "read:dataset",
        "write:model",
        "write:dataset",
        "write:experiment"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "compare_experiments",
      "summary": "Compare persisted modeling experiments by deterministic metrics.",
