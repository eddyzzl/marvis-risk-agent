        "properties": {
          "experiment_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          }
        },
        "required": [
          "experiment_ids"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "experiments": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "experiments"
        ],
        "additionalProperties": false
      },
      "determinism": "deterministic",
      "timeout_seconds": 60,
      "failure_policy": "fail",
      "entrypoint": "tool_compare_experiments",
      "side_effects": [
        "read:experiment"
      ],
      "memory_limit_mb": 2048
    },
