              "type": "string",
              "minLength": 1
            },
            "minItems": 0
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "space": {
            "type": "string",
            "enum": [
              "raw",
              "woe"
            ]
          },
          "split_col": {
            "type": "string",
            "minLength": 1
          },
          "split_value": {},
          "iv_min": {
            "type": "number"
