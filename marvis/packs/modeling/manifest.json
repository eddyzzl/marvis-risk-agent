{
  "name": "modeling",
  "version": "0.4.6",
  "display_name": "Modeling Pack",
  "description": "Modeling readiness, frame preparation, feature selection, training, experiment comparison, probability calibration, PMML export, and V1 validation handoff tools.",
  "module": "marvis.packs.modeling.tools",
  "python_requires": ">=3.10,<3.14",
  "tools": [
    {
      "name": "check_data_quality",
      "summary": "Check modeling data quality issues without changing deterministic metrics.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "dataset_id"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "issues": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "issues"
        ],
        "additionalProperties": false
      },
      "determinism": "deterministic",
      "timeout_seconds": 120,
      "failure_policy": "fail",
      "entrypoint": "tool_check_data_quality",
      "side_effects": [
        "read:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "modeling_readiness",
      "summary": "Evaluate whether a dataset is ready for binary modeling.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "split_col": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "dataset_id",
          "target_col"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ready": {
            "type": "boolean"
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "stats": {
            "type": "object"
          }
        },
        "required": [
          "ready",
          "blockers",
          "warnings",
          "stats"
        ],
        "additionalProperties": false
      },
      "determinism": "deterministic",
      "timeout_seconds": 120,
      "failure_policy": "fail",
      "entrypoint": "tool_modeling_readiness",
      "side_effects": [
        "read:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "reject_inference",
      "summary": "Create a reject-inference augmented modeling dataset using parceling or fuzzy augmentation with explicit assumptions and sample weights.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "decision_col": {
            "type": "string",
            "minLength": 1
          },
          "method": {
            "type": "string",
            "enum": [
              "parceling",
              "fuzzy_augmentation"
            ]
          },
          "score_col": {
            "type": "string",
            "minLength": 1
          },
          "reject_bad_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "reject_weight": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        },
        "required": [
          "dataset_id",
          "target_col",
          "decision_col"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result_dataset_id": {
            "type": "string"
          },
          "target_col": {
            "type": "string"
          },
          "sample_weight_col": {
            "type": "string"
          },
          "diagnostics": {
            "type": "object"
          }
        },
        "required": [
          "result_dataset_id",
          "target_col",
          "sample_weight_col",
          "diagnostics"
        ],
        "additionalProperties": false
      },
      "determinism": "deterministic",
      "timeout_seconds": 180,
      "failure_policy": "fail",
      "entrypoint": "tool_reject_inference",
      "side_effects": [
        "read:dataset",
        "write:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "prepare_modeling_frame",
      "summary": "Create a derived modeling frame with selected columns and deterministic splits.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "feature_cols": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0
          },
          "split_col": {
            "type": "string",
            "minLength": 1
          },
          "split_config": {
            "type": "object"
          },
          "passthrough_cols": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "seed": {
            "type": "integer"
          }
        },
        "required": [
          "dataset_id",
          "target_col",
          "feature_cols"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result_dataset_id": {
            "type": "string"
          },
          "split_counts": {
            "type": "object"
          },
          "split_col": {
            "type": "string"
          },
          "split_values": {
            "type": "object"
          },
          "holdout_values": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "feature_cols": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "result_dataset_id",
          "split_counts"
        ],
        "additionalProperties": false
      },
      "determinism": "stochastic",
      "timeout_seconds": 120,
      "failure_policy": "fail",
      "entrypoint": "tool_prepare_modeling_frame",
      "side_effects": [
        "read:dataset",
        "write:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "make_split",
      "summary": "MODELING G1 split gate: build a derived modeling frame from an arbitrary condition rule set plus the existing random/time fallback, and return per-split counts with a per-split x month/channel distribution table for confirmation.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "feature_cols": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0
          },
          "split_config": {
            "type": "object"
          },
          "passthrough_cols": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "seed": {
            "type": "integer"
          },
          "split_col": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "dataset_id",
          "target_col",
          "feature_cols"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "result_dataset_id": {
            "type": "string"
          },
          "sample_analysis": {
            "type": "object",
            "properties": {
              "split_counts": {
                "type": "object"
              },
              "total_rows": {
                "type": "integer",
                "minimum": 0
              },
              "group_distributions": {
                "type": "object"
              }
            },
            "required": [
              "split_counts",
              "total_rows",
              "group_distributions"
            ],
            "additionalProperties": false
          },
          "split_col": {
            "type": "string"
          },
          "split_values": {
            "type": "object"
          },
          "holdout_values": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "feature_cols": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "result_dataset_id",
          "split_col",
          "sample_analysis"
        ],
        "additionalProperties": false
      },
      "determinism": "stochastic",
      "timeout_seconds": 120,
      "failure_policy": "fail",
      "entrypoint": "tool_make_split",
      "side_effects": [
        "read:dataset",
        "write:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "screen_features",
      "summary": "Leakage-aware univariate KS/IV screen over a wide candidate set; flags suspected target leakage (very high single-feature KS) and model-output/score columns, and proposes a clean candidate set for user confirmation.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 0
          },
          "target_col": {
            "type": "string",
            "minLength": 1
          },
          "target_type": {
            "type": "string"
          },
          "split_col": {
            "type": "string",
            "minLength": 1
          },
          "holdout_values": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "leakage_ks": {
            "type": "number"
          },
          "max_missing_rate": {
            "type": "number"
          },
          "top_k": {
            "type": "integer",
            "minimum": 1
          },
          "batch_size": {
            "type": "integer",
            "minimum": 1
          }
        },
        "required": [
          "dataset_id",
          "features",
          "target_col"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "selected": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ranked": {
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "leakage": {
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "suspected": {
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "unusable": {
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "scores": {
            "type": "object"
          },
          "n_screened": {
            "type": "integer",
            "minimum": 0
          },
          "note": {
            "type": "string"
          }
        },
        "required": [
          "selected",
          "ranked",
          "leakage",
          "suspected",
          "unusable",
          "scores"
        ],
        "additionalProperties": false
      },
      "determinism": "deterministic",
      "timeout_seconds": 300,
      "failure_policy": "fail",
      "entrypoint": "tool_screen_features",
      "side_effects": [
        "read:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "select_features",
      "summary": "Select modeling features using raw or WOE-space IV, correlation, VIF, optional top-k filters, and WOE sign warnings.",
      "input_schema": {
        "type": "object",
