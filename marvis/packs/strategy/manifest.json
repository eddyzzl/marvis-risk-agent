  "python_requires": ">=3.10,<3.14",
  "tools": [
    {
      "name": "vintage_curve",
      "summary": "Compute a strategy-facing vintage curve from the shared deterministic vintage core.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "cohort_col": {
            "type": "string",
            "minLength": 1
          },
          "mob_col": {
            "type": "string",
            "minLength": 1
          },
          "bad_col": {
            "type": "string",
            "minLength": 1
          },
          "mob_max": {
            "type": "integer",
            "minimum": 1
          },
          "ref_mob": {
            "type": "integer",
            "minimum": 1
          },
          "drop_nan_labels": {
            "type": "boolean"
          }
        },
        "required": [
          "dataset_id",
          "cohort_col",
          "mob_col",
          "bad_col"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "cohorts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mob_axis": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "curves": {
            "type": "object"
          },
          "counts": {
            "type": "object"
          },
          "summary": {
            "type": "object"
          },
          "nan_labels_dropped": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "cohorts",
          "mob_axis",
          "curves",
          "counts",
          "summary",
          "nan_labels_dropped"
        ],
        "additionalProperties": false
      },
      "determinism": "deterministic",
      "timeout_seconds": 120,
      "failure_policy": "fail",
      "entrypoint": "tool_vintage_curve",
      "side_effects": [
        "read:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
