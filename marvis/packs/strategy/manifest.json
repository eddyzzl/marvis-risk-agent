            "type": "string",
            "minLength": 1
          },
          "status_col": {
            "type": "string",
            "minLength": 1
          },
          "states": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          }
        },
        "required": [
          "dataset_id",
          "id_col",
          "time_col",
          "status_col",
          "states"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "states": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "matrix": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "number"
              }
            }
          },
          "base_counts": {
            "type": "object"
          }
        },
        "required": [
          "states",
          "matrix",
          "base_counts"
        ],
        "additionalProperties": false
      },
      "determinism": "deterministic",
      "timeout_seconds": 120,
      "failure_policy": "fail",
      "entrypoint": "tool_roll_rate",
      "side_effects": [
        "read:dataset"
      ],
      "memory_limit_mb": 4096
    },
    {
      "name": "profit_calc",
      "summary": "Calculate deterministic segment profitability from EAD, PD, and cost parameters.",
      "input_schema": {
        "type": "object",
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "segment_col": {
            "type": "string",
            "minLength": 1
          },
          "ead_col": {
            "type": "string",
            "minLength": 1
          },
          "pd_col": {
            "type": "string",
            "minLength": 1
          },
          "params": {
            "$ref": "#/$defs/profit_params"
          }
        },
        "required": [
          "dataset_id",
          "ead_col",
          "pd_col",
          "params"
        ],
        "additionalProperties": false,
        "$defs": {
          "profit_params": {
            "type": "object",
            "properties": {
              "annual_rate": {
                "type": "number"
              },
              "funding_rate": {
                "type": "number"
              },
              "lgd": {
                "type": "number"
              },
              "operating_cost_per_loan": {
                "type": "number"
              },
              "term_months": {
                "type": "integer",
                "minimum": 1
              }
            },
            "required": [
              "annual_rate",
              "funding_rate",
              "lgd",
              "operating_cost_per_loan",
              "term_months"
            ],
            "additionalProperties": false
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "results"
        ],
        "additionalProperties": false
      },
      "determinism": "deterministic",
      "timeout_seconds": 120,
      "failure_policy": "fail",
      "entrypoint": "tool_profit_calc",
      "side_effects": [
        "read:dataset"
      ],
      "memory_limit_mb": 4096
    },
